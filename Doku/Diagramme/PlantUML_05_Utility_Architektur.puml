@startuml Wissenstest_05_Utility_Architecture
!theme plain
skinparam classBackgroundColor #F8E8F8
skinparam classBorderColor #AA00AA
skinparam classArrowColor #AA00AA
skinparam fontSize 11

title Wissenstest - Klassendiagramm Teil 5: Utility Classes und Architektur-Übersicht

' ==================== UTILITY CLASSES ====================
class DbConnectionManager {
  <<singleton>>
  -{static} instance: DbConnectionManager
  -dataSource: HikariDataSource
  -config: Properties
  -logger: Logger
  --
  +{static} getInstance(): DbConnectionManager
  +getConnection(): Connection
  +getDataSource(): DataSource
  +closeConnection(Connection): void
  +getPoolStats(): Map<String, Object>
  -initializeDataSource(): void
  -loadConfiguration(): void
  -validateConnection(Connection): boolean
}

class PasswordUtils {
  <<utility>>
  --
  +{static} hashPassword(String password): String
  +{static} verifyPassword(String password, String hash): boolean
  +{static} generatePassword(int length): String
  +{static} isValidPassword(String password): boolean
  +{static} isStrongPassword(String password): boolean
  +{static} getPasswordStrength(String password): int
  -hashWithSHA256(String): String
  -generateSalt(): String
}

class Logger {
  <<utility>>
  --
  +{static} info(String message): void
  +{static} warn(String message): void
  +{static} error(String message): void
  +{static} error(String message, Exception e): void
  +{static} debug(String message): void
  +{static} trace(String message): void
  +{static} setLogLevel(Level): void
  -formatMessage(String): String
  -writeToFile(String, String): void
}

class ConfigManager {
  <<singleton>>
  -{static} instance: ConfigManager
  -properties: Properties
  --
  +{static} getInstance(): ConfigManager
  +getProperty(String key): String
  +getProperty(String key, String defaultValue): String
  +setProperty(String key, String value): void
  +loadFromFile(String path): void
  -parseConfiguration(): void
}

class ValidationUtils {
  <<utility>>
  --
  +{static} isValidEmail(String email): boolean
  +{static} isValidUsername(String username): boolean
  +{static} isValidPassword(String password): boolean
  +{static} isEmpty(String value): boolean
  +{static} isNumeric(String value): boolean
  +{static} sanitizeInput(String input): String
}

class ExceptionHandler {
  <<utility>>
  --
  +{static} handle(Exception e): ErrorResponse
  +{static} handle(Exception e, String context): ErrorResponse
  +{static} logException(Exception e, String message): void
  +{static} isRecoverable(Exception e): boolean
  -mapException(Exception): ErrorResponse
}

' ==================== ERROR RESPONSE CLASS ====================
class ErrorResponse {
  -code: String
  -message: String
  -details: String
  -timestamp: LocalDateTime
  --
  +getCode(): String
  +getMessage(): String
  +getDetails(): String
  +getTimestamp(): LocalDateTime
  +toJsonString(): String
}

' ==================== ARCHITECTURE OVERVIEW ====================
package "Presentation Layer" {
  class JSP_Templates {
    index.jsp
    LoginPage.jsp
    TestRunnerPage.jsp
    AdminPanel.jsp
  }
  
  class JavaScript_Assets {
    app.js
    timer.js
    forms.js
    api.js
  }
}

package "Web/Servlet Layer" {
  class AuthServlet_Ref {
    /auth/*
  }
  class TestServlet_Ref {
    /test/*
  }
  class AdminServlet_Ref {
    /admin/*
  }
}

package "Service Layer" {
  class AuthService_Ref {
    Authentication
    Password Management
  }
  class TestService_Ref {
    Test Management
    Test Execution
  }
  class ProgressionService_Ref {
    Scoring
    Grading
  }
  class AdminService_Ref {
    User Management
    Statistics
  }
}

package "DAO Layer" {
  class UserDao_Ref {
    JdbcUserDao
  }
  class QuestionDao_Ref {
    JdbcQuestionDao
  }
  class TestDao_Ref {
    JdbcTestDao
  }
  class AttemptDao_Ref {
    JdbcAttemptDao
  }
}

package "Data Layer" {
  class PostgreSQL {
    users
    questions
    tests
    attempts
    ...
  }
}

' ==================== RELATIONSHIPS ====================

DbConnectionManager --> HikariDataSource : manages
DbConnectionManager --> Logger : uses
Logger --> ConfigManager : uses
ValidationUtils --> Logger : uses
ExceptionHandler --> Logger : uses
ExceptionHandler --> ErrorResponse : creates

note right of DbConnectionManager
  Singleton Pattern:
  - Nur eine Instanz
  - Verwaltet Connection Pool
  - HikariCP für Performance
  
  Eigenschaften:
  - Lazy Initialization
  - Thread-safe
end note

note right of PasswordUtils
  Sicherheits-Utilities:
  - SHA-256 Hashing
  - Salt-Generierung
  - Passwort-Validierung
  - Strength-Check
end note

note right of Logger
  Zentrale Logging:
  - Info, Warn, Error
  - File & Console Output
  - Configurable Levels
  - Timestamp & Context
end note

note right of ValidationUtils
  Input-Validierung:
  - Email/Username Format
  - Passwort-Anforderungen
  - Input-Sanitization
  - XSS-Prevention
end note

note right of ExceptionHandler
  Zentrale Exception-Behandlung:
  - Mapping zu ErrorResponse
  - Logging & Context
  - Recovery-Check
  - REST API Responses
end note

note bottom of DbConnectionManager
  Verwendete Technologien:
  - HikariCP Connection Pool
  - PostgreSQL JDBC Driver
  - Properties-File Konfiguration
  - Thread-Safe Singleton
end note

@enduml
