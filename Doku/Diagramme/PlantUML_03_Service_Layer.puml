@startuml Wissenstest_03_Service_Layer
!theme plain
skinparam classBackgroundColor #F8F4E8
skinparam classBorderColor #CC6600
skinparam classArrowColor #CC6600
skinparam fontSize 11

title Wissenstest - Klassendiagramm Teil 3: Business Logic Service Layer

' ==================== SERVICE CLASSES ====================
class AuthService {
  -userDao: UserDao
  -passwordUtils: PasswordUtils
  -logger: Logger
  --
  +authenticate(String username, String password): User
  +register(String username, String password, String email): User
  +validatePassword(String password): boolean
  +validateEmail(String email): boolean
  +hashPassword(String password): String
  +verifyPassword(String password, String hash): boolean
  +changePassword(User, String oldPassword, String newPassword): void
  +resetPassword(User, String newPassword): void
  +isUsernameAvailable(String username): boolean
  -validateCredentials(String, String): void
}

class TestService {
  -testDao: TestDao
  -questionDao: QuestionDao
  -attemptDao: AttemptDao
  -questionRepository: QuestionRepository
  -logger: Logger
  --
  +createTest(Test): void
  +updateTest(Test): void
  +deleteTest(int): void
  +getTest(int): Test
  +getAllTests(): List<Test>
  +getTestsByCreator(User): List<Test>
  +getQuestionsForTest(int): List<Question>
  +addQuestionToTest(int testId, int questionId): void
  +removeQuestionFromTest(int testId, int questionId): void
  +startTest(User, Test): Attempt
  +submitTest(Attempt): void
  +getRandomQuestions(Test, int): List<Question>
}

class ProgressionService {
  -attemptDao: AttemptDao
  -answerDao: AnswerDao
  -logger: Logger
  --
  +calculateScore(Attempt): int
  +calculatePercentage(Attempt): double
  +calculateGrade(double percentage): String
  +evaluateAttempt(Attempt): void
  +getAttemptStats(User): Map<String, Object>
  +getTestStats(Test): Map<String, Object>
  +isPassed(Attempt): boolean
  +getPassingRate(Test): double
  +getUserAverageScore(User): double
  +getTestAverageScore(Test): double
  -evaluateAnswers(Attempt): void
  -mapPercentageToGrade(double): String
}

class AdminService {
  -userDao: UserDao
  -testDao: TestDao
  -questionDao: QuestionDao
  -attemptDao: AttemptDao
  -authService: AuthService
  -logger: Logger
  --
  +getAllUsers(): List<User>
  +activateUser(User): void
  +deactivateUser(User): void
  +resetUserPassword(User, String newPassword): void
  +deleteUser(User): void
  +changeUserRole(User, Role): void
  +getSystemStatistics(): Map<String, Object>
  +getUserStatistics(User): Map<String, Object>
  +getQuestionStatistics(): Map<String, Object>
  +getTestStatistics(Test): Map<String, Object>
  +generateReport(Date startDate, Date endDate): String
  +getTotalUsers(): int
  +getActiveUsers(): int
  +getTotalTests(): int
  +getTotalAttempts(): int
  -validateAdminAction(User): void
}

' ==================== UTILITY CLASSES REFERENCED ====================
class PasswordUtils {
  <<utility>>
  --
  +{static} hashPassword(String password): String
  +{static} verifyPassword(String password, String hash): boolean
  +{static} generatePassword(int length): String
  +{static} isValidPassword(String password): boolean
  +{static} isStrongPassword(String password): boolean
}

class Logger {
  <<utility>>
  --
  +{static} info(String message): void
  +{static} warn(String message): void
  +{static} error(String message): void
  +{static} error(String message, Exception e): void
  +{static} debug(String message): void
}

' ==================== INTERFACE REFERENCES ====================
interface UserDao {
}

interface QuestionDao {
}

interface TestDao {
}

interface AttemptDao {
}

interface AnswerDao {
}

class QuestionRepository {
}

' ==================== RELATIONSHIPS ====================

AuthService --> UserDao : uses
AuthService --> PasswordUtils : uses
AuthService --> Logger : uses

TestService --> TestDao : uses
TestService --> QuestionDao : uses
TestService --> AttemptDao : uses
TestService --> QuestionRepository : uses
TestService --> Logger : uses

ProgressionService --> AttemptDao : uses
ProgressionService --> AnswerDao : uses
ProgressionService --> Logger : uses

AdminService --> UserDao : uses
AdminService --> TestDao : uses
AdminService --> QuestionDao : uses
AdminService --> AttemptDao : uses
AdminService --> AuthService : uses
AdminService --> Logger : uses

note right of AuthService
  Verantwortung:
  - Benutzer-Authentifizierung
  - Passwort-Management
  - Registrierung
  - Session-Verwaltung
  
  Nutzt PasswordUtils für
  sichere Passwort-Behandlung
end note

note right of TestService
  Verantwortung:
  - Test-Management (CRUD)
  - Test-Durchführung
  - Fragen-Verwaltung
  - Random-Auswahl von Fragen
  
  Koordiniert mehrere DAOs
end note

note right of ProgressionService
  Verantwortung:
  - Score-Berechnung
  - Prozentuale Quote
  - Noten-Berechnung (1-6)
  - Statistik-Generierung
  - Bestehens-Bewertung
  
  Zentrale Logik für Auswertung
end note

note right of AdminService
  Verantwortung:
  - Benutzerverwaltung
  - System-Statistiken
  - Report-Generierung
  - Admin-Aktionen
  
  Höchste Zugriffsstufe
  benötigt Admin-Rolle
end note

note bottom of AuthService
  Services sind "fat" - sie enthalten
  die gesamte Business-Logik
  und koordinieren die DAOs
end note

@enduml
