@startuml Activity_Authentication

title Activity-Diagramm - Authentifizierungs-Flow

start
:Benutzer öffnet Anwendung;
:URL: http://localhost:8080/wissentest;
:index.jsp wird geladen;

:Session-Cookie prüfen;
if (Session-Cookie vorhanden?) then (Ja)
    :Session-ID aus Cookie lesen;
    :Session-Daten abrufen;
    if (Session noch gültig?) then (Ja)
        :Benutzer-ID aus Session;
        :Zur Dashboard weiterleiten;
        :Benutzer-Dashboard (rolle-spezifisch) anzeigen;
    else (Nein - Abgelaufen)
        :Cookie löschen;
        :Zur Login-Seite;
    endif
else (Nein)
    :Zur Login-Seite weiterleiten;
endif

:Login-Formular anzeigen;
:- Benutzername-Eingabefeld;
:- Passwort-Eingabefeld;
:- Button: "Anmelden";
:- Link: "Passwort vergessen?";
:- Link: "Registrieren";

:Benutzer gibt Credentials ein;
:Benutzername eingeben;
:Passwort eingeben;
:Login-Button klicken;

:Formular auf Server abgesendet (POST);
:AuthService.authenticate() aufrufen;

:Benutzername validieren;
if (Benutzername leer?) then (Ja)
    :Fehlermeldung: "Benutzername erforderlich";
    :Cursor auf Benutzername-Feld;
    stop
else (Nein)
    :Weiter;
endif

:SELECT * FROM users WHERE username = ?;
if (Benutzer in DB gefunden?) then (Nein)
    :Fehlermeldung: "Benutzername oder Passwort falsch";
    :Login-Seite neu laden;
    stop
else (Ja)
    :Benutzer-Datensatz abrufen;
endif

:Passwort validieren;
if (Passwort leer?) then (Ja)
    :Fehlermeldung: "Passwort erforderlich";
    stop
else (Nein)
    :Weiter;
endif

:Gespeichertes Passwort-Hash abrufen;
:Eingegeben Passwort mit Salt hashen;
:PasswordUtil.hashPassword(eingabePasswort, gespeicherterSalt);
:Hashes vergleichen;

if (Hashes gleich?) then (Nein)
    :Fehlermeldung: "Benutzername oder Passwort falsch";
    :Fehlgeschlagener Login-Versuch loggen;
    :Login-Seite neu laden;
    stop
else (Ja)
    :Passwort korrekt;
endif

:Benutzer-Rolle prüfen;
:role aus users-Tabelle lesen;

if (Rolle?) then (admin/teacher)
    :Admin-Dashboard laden;
    :Admin-Panel-Features verfügbar;
    :Optionen: Fragen verwalten, Benutzer, Statistiken;
else (student)
    :Student-Dashboard laden;
    :Optionen: Tests, Lernmodus, Ergebnisse;
endif

:Session erstellen;
:Eindeutige Session-ID generieren;
:Session-Daten speichern:;
:- user_id, role, username;
:- login_time, expiration_time;
:- isAuthenticated = true;

:Session-Cookie erstellen;
:Cookie-Name: JSESSIONID;
:Cookie-Wert: Session-ID;
:Cookie-Attribute:;
:- HttpOnly = true (XSS-Schutz);
:- Secure = true (HTTPS nur);
:- SameSite = Strict (CSRF-Schutz);
:- Max-Age = 30 Minuten;

:Cookie im Response setzen;
:Redirect zum Dashboard;

:Dashboard-Seite wird angezeigt;
:Willkommenstext mit Benutzername;
:Rolle-spezifische Inhalte;

:Benutzer ist authentifiziert;
:Alle nachfolgenden Requests enthalten Session-Cookie;
:Weitere Requests werden validiert;

if (User macht Aktion?) then (Test starten)
    :Zu Test-Durchführung;
else if (Logout)
    :Session beenden;
    :Cookie löschen;
    :Zur Login-Seite;
    stop
else
    :Auf Dashboard verbleiben;
endif

stop

note right
  **Sicherheitsmassnahmen:**
  
  1. **Passwort-Hashing:**
     - PBKDF2 oder bcrypt
     - Mit zufälligem Salt
     - Nicht im Klartext speichern
  
  2. **Session-Management:**
     - HttpOnly Cookie
     - Secure Flag für HTTPS
     - SameSite = Strict
     - Ablauf nach 30 Min
  
  3. **Authentifizierung:**
     - SQL-Injection prävention
     - Generische Fehlermeldungen
     - Login-Versuche loggen
  
  4. **Rollen-Basierte Zugriffskontrolle:**
     - role aus users.role
     - Dashboard-Funktionen prüfen
end note

@enduml
